    "estat-api-v3": {
      "title": "政府統計の総合窓口（e-Stat）API 3.0",
      "publisher": "独立行政法人統計センター",
      "authority_level": "primary",
      "source_type": "api",
      "public_access": true,
      "documentation_url": "https://www.e-stat.go.jp/api/api-info/e-stat-manual3-0",
      "attribution": {
        "source_name": "政府統計の総合窓口（e-Stat）",
        "source_url_required": true
      },
      "access": {
        "mode": "live_api",
        "authentication": "app_id",
        "activation_note": "e-Statの登録内容変更で「API機能」を有効化し、アプリケーションIDを発行する",
        "credential_environment_variable": "ESTAT_APPID",
        "endpoints": [
          "https://api.e-stat.go.jp/rest/3.0/app/json/getStatsList",
          "https://api.e-stat.go.jp/rest/3.0/app/json/getMetaInfo",
          "https://api.e-stat.go.jp/rest/3.0/app/json/getStatsData"
        ]
      },
      "use_boundary": {
        "suitable_for": [
          "統計表の発見",
          "自治体コードと全国統計の取得",
          "取得条件を絞った最新参照"
        ],
        "not_sufficient_for": [
          "自治体固有の予算書・決算書",
          "出典・取得時点を伴わない対外利用"
        ]
      },
      "freshness": {
        "check_method": "最新の国勢調査SURVEY_DATEを保存済みas_ofと比較する",
        "recommended_check_interval_days": 365,
        "period_semantics": "5年ごとの国勢調査基準日。センサス間に新しい集計が公表され得る",
        "failure_policy": "最新SURVEY_DATEを確認できない場合はunknownとする"
      },
      "persistence": {
        "default": "live_with_cache",
        "raw_response": "cache_for_rebuild",
        "sqlite": "normalize_when_repeated_search_or_cross_source_join_is_needed",
        "snapshot": "pin_verified_outputs_used_for_publication"
      }
    },
